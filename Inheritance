// Superclass (Parent)
#include<iostream>
class Animal {
public:
    void eat() {
        std::cout << "Animal is eating..." << std::endl;
    }

    void sleep() {
        std::cout << "Animal is sleeping..." << std::endl;
    }
};

// Subclass (Child) - Inherits from Animal
class Dog : public Animal {
public:
    void bark() {
        std::cout << "Dog is barking!" << std::endl;
    }
};

int main() {
    Dog myDog;

    // Inherited methods (from Animal)
    myDog.eat();
    myDog.sleep();

    // Child class method
    myDog.bark();
    return 0;
}
